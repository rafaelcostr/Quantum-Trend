# Quantum-Trend — variáveis de ambiente
# Copie para .env e preencha as chaves (nunca commite .env)

DATABASE_URL=postgresql://atlas:atlas@localhost:15432/atlas_quant

# Binance Demo — paper trading (https://demo.binance.com)
BINANCE_DEMO_API_KEY=
BINANCE_DEMO_API_SECRET=

# Binance Live — somente após promotion gates
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API
ATLAS_API_HOST=127.0.0.1
ATLAS_API_PORT=8000
ATLAS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# API (frontend dev)
VITE_API_URL=http://127.0.0.1:8000/api

# Operacional
ATLAS_KILL_SWITCH=0
# Live trading — exige opt-in explícito + gates (backtest, walk-forward, paper)
ATLAS_ALLOW_LIVE=0
ATLAS_LIVE_MIN_PAPER_DAYS=7
